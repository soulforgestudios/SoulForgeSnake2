</div>

<!-- Achievements Screen -->
<div id="achievements-layer" class="screen hidden">
    <h2 style="color:var(--accent); letter-spacing:10px; margin-bottom: 25px; text-shadow:0 0 18px rgba(255,206,68,0.9);">ACHIEVEMENTS</h2>
    <div class="achievements-container">
        <div class="achievement-card" id="ach-firstblood">
            <div class="ach-header">
                <div class="ach-icon">🩸</div>
                <div class="ach-info">
                    <div class="ach-title">FIRST BLOOD</div>
                    <div class="ach-desc">Eat your first apple</div>
