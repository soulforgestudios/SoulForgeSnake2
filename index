<div id="achievement-toast"></div>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');

    // Gameplay parameters (modifiable via settings)
    let grid = 20;
    let tileSize; // computed dynamically based on window size
    let snakeThicknessFactor = 0.68; // portion of tileSize
    let snakeMainColor = '#3cf5ff';
    let snakeAltColor = '#4571e3';

    let snake = [];
    let foods = [{ x: 15, y: 10 }];
    let obstacles = [];
    let dir = { x: 1, y: 0 };
    let nextDir = { x: 1, y: 0 };
    let score = 0;
    let gameActive = false;
    let tickRate = 100;
    let lastTick = 0;
    let lerp = 0;
    let walls = true;
    let particles = [];
    let multiFood = false;
    let isPaused = false;
    let lastFrameTime = performance.now();
    let fps = 0;

    // Combos & power-ups
    let comboMultiplier = 1;
    let comboTimer = 0; // ms left to keep combo alive
    const COMBO_WINDOW = 3000; // 3 seconds

    const POWERUP_TYPES = ['speed', 'slow', 'ghost'];
    let powerups = [];
    let activePowerup = null; // { type, timer }

    // Audio (simple flag, you can plug real sounds in later)
    let soundOn = true;

    // High score & leaderboard
    let highScores = JSON.parse(localStorage.getItem('sf_glide_hs')) || { score: 0 };
    document.getElementById('high-score-val').innerText = highScores.score;

    // Achievements (simple example)
    let achievements = {
        firstBlood: false,
        tenStreak: false,
        wallMaster: false,
        ghostWalker: false
    };

    function resizeCanvas() {
        const margin = 40;
        const size = Math.min(window.innerWidth, window.innerHeight) - margin;
        canvas.width = size;
        canvas.height = size;
        tileSize = size / grid;
        if (!gameActive && snake.length > 0) draw();
    }

    window.addEventListener('resize', resizeCanvas);

    window.onload = () => {
        resizeCanvas();

        const i1 = document.getElementById('intro-1');
        const i2 = document.getElementById('intro-2');
        const menu = document.getElementById('menu-layer');

        i1.querySelector('.intro-text').classList.add('animate-text');

        setTimeout(() => {
            i1.classList.add('hidden');
            i2.classList.remove('hidden');
            i2.querySelector('.intro-text').classList.add('animate-text');

            setTimeout(() => {
                i2.classList.add('hidden');
                menu.classList.remove('hidden');
            }, 3500);
        }, 3500);
    };

    function startGame() {
        document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
        document.getElementById('game-layer').classList.remove('hidden');

        const mid = Math.floor(grid / 2);
        snake = [
            { x: mid,     y: mid, px: mid - 1, py: mid },
            { x: mid - 1, y: mid, px: mid - 2, py: mid },
            { x: mid - 2, y: mid, px: mid - 3, py: mid }
        ];

        dir = { x: 1, y: 0 };
        nextDir = { x: 1, y: 0 };
        score = 0;
        gameActive = true;
        isPaused = false;
        lerp = 0;
        lastTick = performance.now();
        lastFrameTime = performance.now();
        particles = [];
        obstacles = [];
        powerups = [];
        activePowerup = null;
        comboMultiplier = 1;
        comboTimer = 0;

        foods = [{ x: randomInt(0, grid - 1), y: randomInt(0, grid - 1) }];
        if (multiFood) {
            while (foods.length < 3) {
                spawnFood();
            }
        }

        document.getElementById('score-val').innerText = score;
        document.getElementById('wall-indicator').innerText = `WALLS: ${walls ? 'ON' : 'OFF'}`;
        document.getElementById('combo-indicator').innerText = `COMBO: x${comboMultiplier}`;
        document.getElementById('pause-badge').style.display = 'none';

        requestAnimationFrame(gameLoop);
    }

    function gameLoop(t) {
        if (!gameActive) return;

        const frameDt = t - lastFrameTime;
        lastFrameTime = t;
        fps = 1000 / frameDt;

        if (!isPaused) {
            const dt = t - lastTick;

            if (dt > tickRate) {
                updateLogic();
                lastTick = t;
                lerp = 0;
            } else {
                lerp = dt / tickRate;
            }
        }

        draw();
        updateDebugConsole();
        requestAnimationFrame(gameLoop);
    }

    function updateLogic() {
        // Handle combo timer
        if (comboTimer > 0) {
            comboTimer -= tickRate;
            if (comboTimer <= 0) {
                comboMultiplier = 1;
                document.getElementById('combo-indicator').innerText = `COMBO: x${comboMultiplier}`;
            }
        }

        // Handle powerup timer
        if (activePowerup) {
            activePowerup.timer -= tickRate;
            if (activePowerup.timer <= 0) {
                endPowerup();
            }
        }

        // Move snake
        dir = nextDir;

        const prevPositions = snake.map(seg => ({ x: seg.x, y: seg.y }));

        let head = {
            x: snake[0].x + dir.x,
            y: snake[0].y + dir.y,
            px: snake[0].x,
            py: snake[0].y
        };

        if (walls && !isGhostActive()) {
            if (head.x < 0 || head.x >= grid || head.y < 0 || head.y >= grid) {
                return gameOver();
            }
        } else {
            head.x = (head.x + grid) % grid;
            head.y = (head.y + grid) % grid;
        }

        // Collision with self
        if (!isGhostActive() && snake.some(s => s.x === head.x && s.y === head.y)) {
            return gameOver();
        }

        // Collision with obstacle
        if (!isGhostActive() && obstacles.some(o => o.x === head.x && o.y === head.y)) {
            return gameOver();
        }

        snake.unshift(head);

        // Check food pickups
        let ateFood = false;
        for (let i = foods.length - 1; i >= 0; i--) {
            const f = foods[i];
            if (head.x === f.x && head.y === f.y) {
                ateFood = true;
                foods.splice(i, 1);
                handleFoodEaten(f);
            }
        }

        if (!ateFood) {
            snake.pop();
        }

        // Spawn new foods
        if (foods.length === 0 || (multiFood && foods.length < 3)) {
            spawnFood();
        }

        // Update segments previous positions
        for (let i = 0; i < snake.length; i++) {
            snake[i].px = prevPositions[i]?.x ?? snake[i].x;
            snake[i].py = prevPositions[i]?.y ?? snake[i].y;
        }

        // Power-up spawn chance
        maybeSpawnPowerup();

        // More obstacles as score climbs
        updateObstacles();
    }

    function handleFoodEaten(f) {
        // Basic scoring with combo
        if (!achievements.firstBlood) {
            achievements.firstBlood = true;
            showAchievement('FIRST BLOOD – Your first apple.');
            playSound('achievement');
            updateAchievementUI();
        }

        comboTimer = COMBO_WINDOW;
        comboMultiplier = Math.min(comboMultiplier + 0.1, 3).toFixed(1);

        const gained = Math.round(1 * comboMultiplier);
        score += gained;

        document.getElementById('score-val').innerText = score;
        document.getElementById('combo-indicator').innerText = `COMBO: x${comboMultiplier}`;

        // Achievements based on combo
        if (!achievements.tenStreak && comboMultiplier >= 2.5) {
            achievements.tenStreak = true;
            showAchievement('COMBO FIEND – Huge streak!');
            playSound('achievement');
            updateAchievementUI();
        }

        // Particles for food
        for (let i = 0; i < 14; i++) {
            particles.push({
                x: f.x * tileSize + tileSize / 2,
                y: f.y * tileSize + tileSize / 2,
                vx: (Math.random() - 0.5) * 6,
                vy: (Math.random() - 0.5) * 6,
                life: 1
            });
        }

        playSound('eat');
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Grid
        for (let i = 0; i < grid; i++) {
            for (let j = 0; j < grid; j++) {
                const baseColor = (i + j) % 2 === 0 ? '#1c2b2c' : '#10191c';
                ctx.fillStyle = baseColor;
                ctx.fillRect(i * tileSize, j * tileSize, tileSize, tileSize);
            }
        }

        // Obstacles
        obstacles.forEach(o => {
            ctx.fillStyle = 'rgba(200,40,40,0.9)';
            ctx.beginPath();
            const cx = o.x * tileSize + tileSize / 2;
            const cy = o.y * tileSize + tileSize / 2;
            const r = tileSize * 0.38;
            ctx.moveTo(cx + r, cy);
            for (let k = 1; k < 5; k++) {
                const angle = (Math.PI * 2 * k) / 5;
                ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
            }
            ctx.closePath();
            ctx.fill();
        });

        // Food (glowing orbs)
        foods.forEach(food => {
            const fx = food.x * tileSize + tileSize / 2;
            const fy = food.y * tileSize + tileSize / 2;
            const fr = tileSize / 2 - 4;

            const g = ctx.createRadialGradient(fx, fy, fr * 0.1, fx, fy, fr * 1.2);
            g.addColorStop(0, 'rgba(255, 206, 68, 1)');
            g.addColorStop(0.5, 'rgba(255, 100, 80, 0.9)');
            g.addColorStop(1, 'rgba(255, 206, 68, 0)');
            ctx.fillStyle = g;
            ctx.beginPath();
            ctx.arc(fx, fy, fr * 1.2, 0, Math.PI * 2);
            ctx.fill();

            ctx.fillStyle = '#ffce44';
            ctx.beginPath();
            ctx.arc(fx, fy, fr * 0.7, 0, Math.PI * 2);
            ctx.fill();
        });

        // Powerups
        powerups.forEach(p => {
            const px = p.x * tileSize + tileSize / 2;
            const py = p.y * tileSize + tileSize / 2;
            const r = tileSize * 0.3;
            ctx.save();
            ctx.translate(px, py);
            ctx.rotate((performance.now() / 400) % (Math.PI * 2));
            ctx.strokeStyle = p.type === 'speed' ? '#ff6bd5' : p.type === 'slow' ? '#3cf5ff' : '#9b59b6';
            ctx.lineWidth = 3;
            ctx.beginPath();
            ctx.rect(-r, -r, r * 2, r * 2);
            ctx.stroke();
            ctx.restore();
        });

        // Snake body line
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.strokeStyle = snakeAltColor;
        ctx.lineWidth = tileSize * snakeThicknessFactor;
        ctx.beginPath();

        snake.forEach((s, i) => {
            const curX = (s.px + (s.x - s.px) * lerp) * tileSize + tileSize / 2;
            const curY = (s.py + (s.y - s.py) * lerp) * tileSize + tileSize / 2;

            if (i === 0) ctx.moveTo(curX, curY);
            else ctx.lineTo(curX, curY);
        });

        ctx.stroke();

        // Head
        const h = snake[0];
        const hX = (h.px + (h.x - h.px) * lerp) * tileSize + tileSize / 2;
        const hY = (h.py + (h.y - h.py) * lerp) * tileSize + tileSize / 2;

        ctx.fillStyle = snakeMainColor;
        ctx.beginPath();
        ctx.arc(hX, hY, tileSize * snakeThicknessFactor / 1.7, 0, Math.PI * 2);
        ctx.fill();

        // Eyes
        ctx.fillStyle = 'white';
        const eyeOffsetX = 0.18 * tileSize;
        const eyeOffsetY = -0.1 * tileSize;
        const eyeRadius = 0.12 * tileSize;

        ctx.beginPath();
        ctx.arc(hX - eyeOffsetX, hY + eyeOffsetY, eyeRadius, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(hX + eyeOffsetX, hY + eyeOffsetY, eyeRadius, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = 'black';
        const pupilRadius = eyeRadius * 0.45;
        const lookX = dir.x * (eyeRadius * 0.4);
        const lookY = dir.y * (eyeRadius * 0.4);

        ctx.beginPath();
        ctx.arc(hX - eyeOffsetX + lookX, hY + eyeOffsetY + lookY, pupilRadius, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(hX + eyeOffsetX + lookX, hY + eyeOffsetY + lookY, pupilRadius, 0, Math.PI * 2);
        ctx.fill();

        // Particles
        particles = particles.filter(p => p.life > 0);
        particles.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            p.life -= 0.04;
            ctx.globalAlpha = p.life;
            ctx.fillStyle = '#ffce44';
            ctx.fillRect(p.x, p.y, 4, 4);
            ctx.globalAlpha = 1;
        });

        // Powerup indicator (simple halo around head)
        if (activePowerup) {
            ctx.strokeStyle = activePowerup.type === 'speed' ? '#ff6bd5' : activePowerup.type === 'slow' ? '#3cf5ff' : '#9b59b6';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(hX, hY, tileSize * snakeThicknessFactor, 0, Math.PI * 2);
            ctx.stroke();
        }
    }

    function gameOver() {
        gameActive = false;
        playSound('death');

        if (score > highScores.score) {
            highScores.score = score;
            localStorage.setItem('sf_glide_hs', JSON.stringify(highScores));
        }

        if (walls && !achievements.wallMaster && score >= 25) {
            achievements.wallMaster = true;
            showAchievement('WALL MASTER – 25+ with walls.');
            playSound('achievement');
            updateAchievementUI();
        }
        if (activePowerup && activePowerup.type === 'ghost' && !achievements.ghostWalker) {
            achievements.ghostWalker = true;
            showAchievement('GHOST WALKER – Fell with ghost power.');
            playSound('achievement');
            updateAchievementUI();
        }

        document.getElementById('final-score').innerText = score;
        document.getElementById('best-score').innerText = highScores.score;
        document.getElementById('high-score-val').innerText = highScores.score;
        document.getElementById('achievements-summary').innerText = summarizeAchievements();

        document.getElementById('game-layer').classList.add('hidden');
        document.getElementById('over-layer').classList.remove('hidden');
    }

    window.addEventListener('keydown', e => {
        if (e.key === 'ArrowUp'   || e.key === 'w') queueDirection(0, -1);
        if (e.key === 'ArrowDown' || e.key === 's') queueDirection(0, 1);
        if (e.key === 'ArrowLeft' || e.key === 'a') queueDirection(-1, 0);
        if (e.key === 'ArrowRight'|| e.key === 'd') queueDirection(1, 0);
        if (e.key.toLowerCase() === 'p') togglePause();
    });

    function queueDirection(x, y) {
        if (isPaused || !gameActive) return;
        // prevent 180-degree turns
        if (x === -dir.x && y === -dir.y) return;
        if (x === dir.x && y === dir.y) return;
        nextDir = { x, y };
    }

    function randomInt(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function spawnFood() {
        let spot;
        let safety = 0;
        do {
            spot = {
                x: randomInt(0, grid - 1),
                y: randomInt(0, grid - 1)
            };
            safety++;
        } while (
            (snake.some(s => s.x === spot.x && s.y === spot.y) ||
             foods.some(f => f.x === spot.x && f.y === spot.y) ||
             obstacles.some(o => o.x === spot.x && o.y === spot.y))
            && safety < 200
        );
        foods.push(spot);
    }

    function maybeSpawnPowerup() {
        if (powerups.length > 0 || Math.random() > 0.05) return; // 5% chance per tick

        let type = POWERUP_TYPES[randomInt(0, POWERUP_TYPES.length - 1)];
        let spot;
        let safety = 0;
        do {
            spot = { x: randomInt(0, grid - 1), y: randomInt(0, grid - 1) };
            safety++;
        } while (
            (snake.some(s => s.x === spot.x && s.y === spot.y) ||
             foods.some(f => f.x === spot.x && f.y === spot.y) ||
             obstacles.some(o => o.x === spot.x && o.y === spot.y))
            && safety < 200
        );
        powerups.push({ ...spot, type });
    }

    function updateObstacles() {
        const desired = Math.min(Math.floor(score / 5), 12);
        while (obstacles.length < desired) {
            let spot = { x: randomInt(0, grid - 1), y: randomInt(0, grid - 1) };
            if (
                !snake.some(s => s.x === spot.x && s.y === spot.y) &&
                !foods.some(f => f.x === spot.x && f.y === spot.y) &&
                !obstacles.some(o => o.x === spot.x && o.y === spot.y)
            ) {
                obstacles.push(spot);
            }
        }
    }

    function togglePause() {
        if (!gameActive) return;
        isPaused = !isPaused;
        document.getElementById('pause-badge').style.display = isPaused ? 'block' : 'none';
    }

    function showBoard() {
        document.getElementById('menu-layer').classList.add('hidden');
        document.getElementById('board-layer').classList.remove('hidden');
        document.getElementById('leaderboard-list').innerHTML =
            `<div class="score-entry" style="display:flex;justify-content:space-between;font-family:sans-serif;font-size:1.1rem;">
                <span>1. Soul Master</span><span>${highScores.score}</span>
            </div>`;
    }

    function showSettings() {
        document.getElementById('menu-layer').classList.add('hidden');
        document.getElementById('settings-layer').classList.remove('hidden');
    }

    function showCredits() {
        document.getElementById('menu-layer').classList.add('hidden');
        document.getElementById('credits-layer').classList.remove('hidden');
    }

    function showAchievements() {
        document.getElementById('menu-layer').classList.add('hidden');
        document.getElementById('achievements-layer').classList.remove('hidden');
        updateAchievementUI();
    }

    function hideScreens() {
        document.querySelectorAll('.screen').forEach(s => {
            if (s.id === 'menu-layer') s.classList.remove('hidden');
            else s.classList.add('hidden');
        });
    }

    function setTick(t) {
        tickRate = t;
        document.getElementById('dbg-tick').innerText = tickRate;
    }

    function toggleWalls() {
        walls = !walls;
        document.getElementById('wall-btn').innerText = `Walls: ${walls ? 'ON' : 'OFF'}`;
        document.getElementById('wall-indicator').innerText = `WALLS: ${walls ? 'ON' : 'OFF'}`;
    }

    function toggleMultiFood() {
        multiFood = !multiFood;
        document.getElementById('multi-food-btn').innerText = `Multi Food: ${multiFood ? 'ON' : 'OFF'}`;
    }

    function setGrid(newGrid) {
        grid = newGrid;
        resizeCanvas();
        if (gameActive) {
            startGame();
        }
    }

    function setSnakeSize(factor) {
        snakeThicknessFactor = factor;
    }

    function setSnakeColor(main, alt) {
        snakeMainColor = main;
        snakeAltColor = alt;
    }

    function toggleAudio() {
        soundOn = !soundOn;
        document.getElementById('audio-toggle').innerText = `Sound: ${soundOn ? 'ON' : 'OFF'}`;
    }

    function playSound(type) {
        if (!soundOn) return;
        
        const soundMap = {
            'eat': 'sounds/eat.mp3',
            'death': 'sounds/death.mp3',
            'power': 'sounds/powerup.mp3',
            'achievement': 'sounds/achievement.mp3',
            'menuselect': 'sounds/menuselect.mp3'
        };

        const filepath = soundMap[type];
        if (filepath) {
            try {
                const audio = new Audio(filepath);
                audio.volume = 0.5;
                audio.play().catch(e => console.log('Audio play failed:', e));
            } catch (e) {
                console.log('Audio error:', e);
            }
        }
    }

    function isGhostActive() {
        return activePowerup && activePowerup.type === 'ghost';
    }

    // Check for powerup pickups inside updateLogic? We'll hook here by adding another function.
    const originalUpdateLogic = updateLogic;
    updateLogic = function wrappedUpdateLogic() {
        originalUpdateLogicCore();
    };

    function originalUpdateLogicCore() {
        // This is just the body of updateLogic we defined above, but we already used it.
        // To keep things consistent, we won't duplicate logic here.
        // In a real refactor, you would split movement, collision, powerups, etc.
    }

    // We already called updateLogic earlier, so we need to integrate powerup pickup directly there.
    // For simplicity, hook into snake head after movement each tick by overriding requestAnimationFrame logic
    // but you already have the full collision; we can add pickup detection to the updateLogic we wrote above.

    // So we add this helper and call it inside updateLogic after snake has moved.
    function checkPowerupPickup(head) {
        for (let i = powerups.length - 1; i >= 0; i--) {
            const p = powerups[i];
            if (p.x === head.x && p.y === head.y) {
                activatePowerup(p.type);
                powerups.splice(i, 1);
                break;
            }
        }
    }

    // Patch: monkey-patch updateLogic to also call checkPowerupPickup.
    // Re-define updateLogic with full content including previous logic + powerups.

    updateLogic = function() {
        // Handle combo timer
        if (comboTimer > 0) {
            comboTimer -= tickRate;
            if (comboTimer <= 0) {
                comboMultiplier = 1;
                document.getElementById('combo-indicator').innerText = `COMBO: x${comboMultiplier}`;
            }
        }

        // Handle powerup timer
        if (activePowerup) {
            activePowerup.timer -= tickRate;
            if (activePowerup.timer <= 0) {
                endPowerup();
            }
        }

        // Move snake
        dir = nextDir;

        const prevPositions = snake.map(seg => ({ x: seg.x, y: seg.y }));

        let head = {
            x: snake[0].x + dir.x,
            y: snake[0].y + dir.y,
            px: snake[0].x,
            py: snake[0].y
        };

        if (walls && !isGhostActive()) {
            if (head.x < 0 || head.x >= grid || head.y < 0 || head.y >= grid) {
                return gameOver();
            }
        } else {
            head.x = (head.x + grid) % grid;
            head.y = (head.y + grid) % grid;
        }

        if (!isGhostActive() && snake.some(s => s.x === head.x && s.y === head.y)) {
            return gameOver();
        }

        if (!isGhostActive() && obstacles.some(o => o.x === head.x && o.y === head.y)) {
            return gameOver();
        }

        snake.unshift(head);

        let ateFood = false;
        for (let i = foods.length - 1; i >= 0; i--) {
            const f = foods[i];
            if (head.x === f.x && head.y === f.y) {
                ateFood = true;
                foods.splice(i, 1);
                handleFoodEaten(f);
            }
        }

        if (!ateFood) {
            snake.pop();
        }

        for (let i = 0; i < snake.length; i++) {
            snake[i].px = prevPositions[i]?.x ?? snake[i].x;
            snake[i].py = prevPositions[i]?.y ?? snake[i].y;
        }

        if (foods.length === 0 || (multiFood && foods.length < 3)) {
            spawnFood();
        }

        // Check powerup pickup
        checkPowerupPickup(head);

        maybeSpawnPowerup();
        updateObstacles();
    };

    function activatePowerup(type) {
        playSound('power');
        const DURATION = 6000; // ms

        if (type === 'speed') {
            tickRate = Math.max(40, tickRate * 0.6);
        } else if (type === 'slow') {
            tickRate = Math.min(200, tickRate * 1.6);
        } else if (type === 'ghost') {
            // nothing special here other than collisions skipping walls/obstacles
        }

        activePowerup = { type, timer: DURATION };

        if (type === 'ghost') {
            showAchievement('GHOST MODE – Phase through fate.');
        }
    }

    function endPowerup() {
        if (!activePowerup) return;
        // Reset tickRate to default-ish after speed/slow.
        if (activePowerup.type === 'speed' || activePowerup.type === 'slow') {
            tickRate = 100; // or track last chosen speed if you want
        }
        activePowerup = null;
    }

    function updateDebugConsole() {
        document.getElementById('dbg-fps').innerText = fps.toFixed(0);
        document.getElementById('dbg-tick').innerText = tickRate;
        document.getElementById('dbg-seg').innerText = snake.length;
        document.getElementById('dbg-food').innerText = foods.length;
        document.getElementById('dbg-obs').innerText = obstacles.length;
    }

    function showAchievement(text) {
        const el = document.getElementById('achievement-toast');
        el.textContent = text;
        el.classList.add('visible');
        setTimeout(() => {
            el.classList.remove('visible');
        }, 2500);
    }

    function summarizeAchievements() {
        const unlocked = [];
        if (achievements.firstBlood) unlocked.push('First Blood');
        if (achievements.tenStreak) unlocked.push('Combo Fiend');
        if (achievements.wallMaster) unlocked.push('Wall Master');
        if (achievements.ghostWalker) unlocked.push('Ghost Walker');
        if (unlocked.length === 0) return 'No achievements yet. The Forge awaits.';
        return 'Unlocked: ' + unlocked.join(', ');
    }

    function updateAchievementUI() {
        const cardMap = {
            'firstBlood': 'ach-firstblood',
            'tenStreak': 'ach-tenstreak',
            'wallMaster': 'ach-wallmaster',
            'ghostWalker': 'ach-ghostwalker'
        };

        for (const [key, cardId] of Object.entries(cardMap)) {
            const card = document.getElementById(cardId);
            const statusEl = card.querySelector('.ach-status');
            if (achievements[key]) {
                card.classList.add('unlocked');
                card.classList.remove('locked');
                statusEl.textContent = 'UNLOCKED';
                statusEl.classList.add('unlocked');
                statusEl.classList.remove('locked');
            } else {
                card.classList.add('locked');
                card.classList.remove('unlocked');
                statusEl.textContent = 'LOCKED';
                statusEl.classList.remove('unlocked');
                statusEl.classList.add('locked');
            }
        }
    }
</script>

