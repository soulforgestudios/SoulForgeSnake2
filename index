<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snake: SoulForge Edition </title>
    <style>
        :root {
            --bg: #050508;
            --bg-grad-1: #050508;
            --bg-grad-2: #15152b;
            --bg-grad-3: #2b1040;
            --accent: #ffce44;
            --accent-2: #ff6bd5;
            --accent-3: #3cf5ff;
            --grass-1: #1c2b2c;
            --grass-2: #10191c;
            --snake-main: #3cf5ff;
            --snake-alt: #4571e3;
            --text: #ffffff;
            --font: 'Cinzel', serif;
            --glass: rgba(9, 11, 29, 0.5);
            --border: rgba(255, 206, 68, 0.3);
        }

        * { box-sizing: border-box; }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background:
              radial-gradient(circle at top left, var(--bg-grad-3), transparent 60%),
              radial-gradient(circle at bottom right, var(--accent-2), transparent 65%),
              linear-gradient(135deg, var(--bg-grad-1), var(--bg-grad-2));
            color: var(--text);
            font-family: var(--font);
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            inset: -20%;
            background: radial-gradient(circle at center, rgba(255,255,255,0.05), transparent 60%);
            mix-blend-mode: soft-light;
            opacity: 0.6;
            pointer-events: none;
            animation: bg-pulse 12s ease-in-out infinite alternate;
        }

        @keyframes bg-pulse {
            0% { transform: scale(1); opacity: 0.4; }
            100% { transform: scale(1.1); opacity: 0.8; }
        }

        .screen {
            position: fixed;
            inset: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(12px);
            background: radial-gradient(circle at top, rgba(0,0,0,0.75), rgba(0,0,0,0.92));
            z-index: 1000;
            transition: transform 0.6s, opacity 0.6s;
        }

        .hidden {
            opacity: 0;
            pointer-events: none;
            transform: scale(1.05);
        }

        /* Intro Animations */
        .intro-text {
            font-size: 3.5rem;
            letter-spacing: 20px;
            text-transform: uppercase;
            text-align: center;
            opacity: 0;
            text-shadow:
              0 0 15px rgba(60,245,255,0.9),
              0 0 40px rgba(255,107,213,0.9);
        }

        .animate-text {
            animation: soulFade 3.5s forwards;
        }

        @keyframes soulFade {
            0% { opacity: 0; transform: scale(0.9); filter: blur(10px); }
            30% { opacity: 1; transform: scale(1); filter: blur(0px); }
            70% { opacity: 1; }
            100% { opacity: 0; transform: scale(1.1); filter: blur(5px); }
        }

        /* UI Styling */
        .btn-ui {
            background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
            border: 1px solid var(--border);
            color: white;
            padding: 18px 45px;
            font-size: 0.9rem;
            letter-spacing: 6px;
            cursor: pointer;
            transition: 0.25s ease-out;
            text-transform: uppercase;
            margin: 12px;
            min-width: 300px;
            backdrop-filter: blur(10px);
            border-radius: 8px;
            box-shadow:
              0 0 0 1px rgba(255,255,255,0.04),
              0 0 18px rgba(0,0,0,0.85);
            position: relative;
            overflow: hidden;
        }

        .btn-ui::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.15), transparent);
            transform: translateX(-120%);
            transition: transform 0.5s ease-out;
        }

        .btn-ui:hover::after {
            transform: translateX(120%);
        }

        .btn-ui:hover {
            background: linear-gradient(135deg, var(--accent-3), var(--accent-2));
            color: #050506;
            transform: translateY(-4px) scale(1.02);
            border-color: rgba(255,255,255,0.8);
            box-shadow:
              0 0 0 1px rgba(255,255,255,0.3),
              0 0 30px rgba(255,107,213,0.8);
        }

        #stats-bar {
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 10px 20px;
            background: linear-gradient(90deg, rgba(69,113,227,0.95), rgba(60,245,255,0.95));
            border-radius: 18px 18px 0 0;
            font-family: sans-serif;
            font-weight: bold;
            font-size: 1.2rem;
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1100;
            min-width: 260px;
            color: #050506;
            box-shadow:
              0 0 0 1px rgba(255,255,255,0.12),
              0 12px 30px rgba(0,0,0,0.9);
            animation: stats-pulse 6s ease-in-out infinite;
        }

        @keyframes stats-pulse {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(-2px); }
        }

        #gameCanvas {
            border: 3px solid rgba(60,245,255,0.9);
            border-radius: 18px;
            box-shadow:
              0 0 25px rgba(60,245,255,0.5),
              0 30px 60px rgba(0,0,0,0.9);
            display: block;
            background: radial-gradient(circle at center, rgba(15, 20, 40, 0.9), #050508);
        }

        .game-wrapper {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container-box {
            background: radial-gradient(circle at top, rgba(255,255,255,0.06), rgba(5,5,8,0.95));
            padding: 40px;
            border-radius: 25px;
            width: 420px;
            text-align: center;
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            box-shadow:
              0 20px 45px rgba(0,0,0,0.85),
              0 0 0 1px rgba(255,255,255,0.04);
        }

        /* Scrolling Credits */
        .credits-window {
            height: 350px;
            width: 100%;
            overflow: hidden;
            position: relative;
            mask-image: linear-gradient(transparent, black 20%, black 80%, transparent);
        }

        .credits-wrap {
            position: relative;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: scrollUp 25s linear infinite;
        }

        @keyframes scrollUp {
            from { transform: translateY(100%); }
            to { transform: translateY(-130%); }
        }

        .credit-header {
            color: var(--accent-3);
            font-size: 11px;
            letter-spacing: 5px;
            margin-top: 40px;
            text-transform: uppercase;
            opacity: 0.8;
        }

        .credit-name {
            font-size: 24px;
            margin-bottom: 8px;
            font-weight: bold;
        }

        /* Dev Notes (top-right) */
        #dev-notes {
            position: fixed;
            top: 15px;
            right: 15px;
            background: rgba(5,5,8,0.82);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            color: var(--text);
            font-family: sans-serif;
            font-size: 11px;
            max-width: 260px;
            z-index: 1200;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.85);
        }

        .dev-title {
            font-size: 10px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--accent-3);
            margin-bottom: 6px;
        }

        .dev-line {
            opacity: 0.75;
            margin-bottom: 3px;
        }

        /* Version footer (bottom-right) */
        #version-footer {
            position: fixed;
            right: 15px;
            bottom: 12px;
            font-family: sans-serif;
            font-size: 11px;
            letter-spacing: 1px;
            color: rgba(255, 255, 255, 0.9);
            background: rgba(5,5,8,0.85);
            border-radius: 8px;
            padding: 6px 10px;
            border: 1px solid var(--border);
            backdrop-filter: blur(8px);
            z-index: 1200;
            box-shadow: 0 10px 25px rgba(0,0,0,0.9);
        }

        /* Settings sections */
        .settings-section-title {
            font-family: sans-serif;
            font-size: 0.8rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--accent-3);
            margin-top: 10px;
            margin-bottom: 2px;
        }

        .settings-row {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
        }

        .settings-row .btn-ui {
            min-width: 140px;
            padding: 10px 18px;
            margin: 6px;
            letter-spacing: 3px;
            font-size: 0.7rem;
        }

        /* Mobile controls */
        #mobile-controls {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: none;
            flex-direction: column;
            align-items: center;
            z-index: 1150;
        }

        .mobile-row {
            display: flex;
            justify-content: center;
        }

        .mobile-btn {
            width: 60px;
            height: 60px;
            margin: 6px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.4);
            background: radial-gradient(circle at top, rgba(255,255,255,0.1), rgba(5,5,8,0.9));
            color: white;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            user-select: none;
            box-shadow: 0 8px 18px rgba(0,0,0,0.8);
        }

        .mobile-btn:active {
            transform: translateY(2px) scale(0.97);
            box-shadow: 0 4px 10px rgba(0,0,0,0.8);
        }

        /* Pause badge */
        #pause-badge {
            position: absolute;
            top: 60px;
            left: 50%;
            transform: translateX(-50%);
            font-family: sans-serif;
            font-size: 0.9rem;
            letter-spacing: 5px;
            padding: 8px 14px;
            border-radius: 14px;
            border: 1px solid rgba(255,255,255,0.35);
            background: rgba(5,5,8,0.9);
            color: rgba(255,255,255,0.85);
            z-index: 1120;
            display: none;
        }

        /* Debug console */
        #debug-console {
            position: fixed;
            left: 15px;
            bottom: 12px;
            font-family: monospace;
            font-size: 10px;
            color: rgba(255,255,255,0.8);
            background: rgba(5,5,8,0.85);
            border-radius: 8px;
            padding: 6px 10px;
            border: 1px solid rgba(255,255,255,0.15);
            backdrop-filter: blur(8px);
            z-index: 1200;
            max-width: 200px;
        }

        #debug-console span.label {
            color: var(--accent-3);
        }

        /* Achievements */
        #achievement-toast {
            position: fixed;
            top: 90px;
            right: 50%;
            transform: translateX(50%);
            background: linear-gradient(135deg, rgba(60,245,255,0.95), rgba(255,206,68,0.95));
            color: #050506;
            font-family: sans-serif;
            font-size: 0.9rem;
            padding: 10px 18px;
            border-radius: 999px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.85);
            border: 1px solid rgba(255,255,255,0.6);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s, transform 0.4s;
            z-index: 1300;
            letter-spacing: 2px;
        }

        #achievement-toast.visible {
            opacity: 1;
            transform: translateX(50%) translateY(0px);
        }

        /* Achievements Screen - Xbox 360 Style */
        .achievements-container {
            width: 100%;
            max-width: 600px;
            max-height: 400px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 0 10px;
        }

        .achievement-card {
            background: linear-gradient(135deg, rgba(69,113,227,0.15), rgba(60,245,255,0.08));
            border: 1px solid rgba(60,245,255,0.4);
            border-radius: 8px;
            padding: 12px;
            transition: all 0.3s ease;
            cursor: default;
        }

        .achievement-card:hover {
            background: linear-gradient(135deg, rgba(69,113,227,0.25), rgba(60,245,255,0.15));
            border-color: rgba(60,245,255,0.7);
            box-shadow: 0 0 15px rgba(60,245,255,0.3);
        }

        .achievement-card.locked {
            opacity: 0.6;
            border-color: rgba(255,255,255,0.15);
        }

        .achievement-card.locked:hover {
            opacity: 0.7;
        }

        .ach-header {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .ach-icon {
            font-size: 2.2rem;
            min-width: 50px;
            text-align: center;
        }

        .ach-info {
            flex: 1;
        }

        .ach-title {
            font-family: sans-serif;
            font-size: 0.95rem;
            font-weight: bold;
            color: var(--accent-3);
            margin-bottom: 2px;
            letter-spacing: 1px;
        }

        .ach-desc {
            font-family: sans-serif;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.6);
        }

        .ach-score {
            font-family: sans-serif;
            font-size: 0.9rem;
            font-weight: bold;
            color: var(--accent);
            text-align: right;
            min-width: 45px;
        }

        .ach-status {
            font-family: sans-serif;
            font-size: 0.65rem;
            letter-spacing: 2px;
            margin-top: 8px;
            padding: 4px 8px;
            border-radius: 4px;
            text-align: center;
            font-weight: bold;
        }

        .ach-status.unlocked {
            background: rgba(60,245,255,0.3);
            color: var(--accent-3);
            border: 1px solid rgba(60,245,255,0.5);
        }

        .ach-status.locked {
            background: rgba(100,100,100,0.2);
            color: rgba(255,255,255,0.4);
            border: 1px solid rgba(100,100,100,0.3);
        }

        @media (max-width: 900px) {
            .achievements-container {
                max-height: 350px;
            }
        }

        @media (max-width: 600px) {
            .achievements-container {
                max-height: 300px;
            }
            .ach-icon {
                font-size: 1.8rem;
            }
        }

        #achievement-toast.visible {
            opacity: 1;
            transform: translateX(50%) translateY(0px);
        }

        @media (max-width: 900px) {
            #mobile-controls { display: flex; }
        }

        @media (max-width: 600px) {
            .intro-text { font-size: 2.3rem; letter-spacing: 10px; }
            #stats-bar { font-size: 1rem; padding: 6px 12px; }
            .container-box { width: 90%; padding: 25px 16px; }
            .btn-ui { min-width: 220px; padding: 12px 24px; letter-spacing: 4px; }
        }
    </style>
</head>
<body>
<!-- Dev notes overlay -->
<div id="dev-notes">
    <div class="dev-title">DEV NOTES 1.0.0 RELEASE</div>
    <div class="dev-line">– Smooth glide interpolation</div>
    <div class="dev-line">– Walls toggle (ON/OFF, wrap like Google)</div>
    <div class="dev-line">– Speed, grid, snake & color presets</div>
    <div class="dev-line">– Power-ups, obstacles, combos</div>
</div>

<div id="intro-1" class="screen">
    <div class="intro-text">SoulForge Studios</div>
</div>

<div id="intro-2" class="screen hidden">
    <div class="intro-text" style="font-size: 1.5rem;">All Rights Reserved</div>
</div>

<div id="menu-layer" class="screen hidden">
    <h1 style="font-size: 85px; color: var(--accent); letter-spacing: 20px; margin:0; text-align:center; text-shadow:0 0 25px rgba(255,206,68,0.9);">SOULFORGE SNAKE 2</h1>
    <button class="btn-ui" onclick="startGame()">Enter the Forge</button>
    <button class="btn-ui" onclick="showBoard()">Hall of Fame</button>
    <button class="btn-ui" onclick="showSettings()">Settings</button>
    <button class="btn-ui" onclick="showCredits()">Credits</button>
    <button class="btn-ui" onclick="showAchievements()">Achievements</button>
</div>

<div id="game-layer" class="screen hidden">
    <div class="game-wrapper">
        <div id="stats-bar">
            <span>🍎 <span id="score-val">0</span></span>
            <span>🏆 <span id="high-score-val">0</span></span>
            <span id="combo-indicator" style="font-size:0.8rem;">COMBO: x1</span>
            <span id="wall-indicator" style="font-size:0.8rem;">WALLS: ON</span>
            <button class="btn-ui" style="min-width:120px;padding:6px 10px;font-size:0.6rem;letter-spacing:3px;" onclick="togglePause()">PAUSE</button>
        </div>
        <div id="pause-badge">PAUSED</div>
        <canvas id="gameCanvas"></canvas>
    </div>
</div>

<div id="over-layer" class="screen hidden">
    <h2 style="color:#e74c3c; letter-spacing:10px; font-size: 3rem; text-shadow:0 0 24px rgba(231,76,60,0.9);">FORGE COLD</h2>
    <div class="container-box">
        <p style="font-family: sans-serif; font-size: 1.5rem; margin-bottom: 5px;">
            Final Score: <span id="final-score" style="color:var(--accent)">0</span>
        </p>
        <p style="font-family: sans-serif; font-size: 0.9rem; opacity: 0.7; margin-bottom: 10px;">
            Best: <span id="best-score">0</span>
        </p>
        <p style="font-family: sans-serif; font-size: 0.8rem; opacity:0.7; margin-bottom: 30px;" id="achievements-summary"></p>
        <button class="btn-ui" onclick="startGame()">Ignite Again</button>
        <button class="btn-ui" onclick="hideScreens()">Main Menu</button>
    </div>
</div>

<!-- Settings Screen -->
<div id="settings-layer" class="screen hidden">
    <h2 style="color:var(--accent); letter-spacing:10px; margin-bottom: 25px; text-shadow:0 0 18px rgba(255,206,68,0.9);">SETTINGS</h2>
    <div class="container-box">
        <!-- Gameplay section -->
        <div class="settings-section-title">Gameplay</div>
        <div class="settings-row">
            <button class="btn-ui" onclick="setTick(150)">Slow</button>
            <button class="btn-ui" onclick="setTick(100)">Soul</button>
            <button class="btn-ui" onclick="setTick(70)">Hyper</button>
        </div>
        <div class="settings-row">
            <button class="btn-ui" id="wall-btn" onclick="toggleWalls()">Walls: ON</button>
            <button class="btn-ui" id="multi-food-btn" onclick="toggleMultiFood()">Multi Food: OFF</button>
        </div>

        <!-- Grid / Square Size (actually grid size) -->
        <div class="settings-section-title">Grid Size</div>
        <div class="settings-row">
            <button class="btn-ui" onclick="setGrid(16)">Cozy (16x16)</button>
            <button class="btn-ui" onclick="setGrid(20)">Classic (20x20)</button>
            <button class="btn-ui" onclick="setGrid(24)">Tight (24x24)</button>
        </div>

        <!-- Snake size -->
        <div class="settings-section-title">Snake Size</div>
        <div class="settings-row">
            <button class="btn-ui" onclick="setSnakeSize(0.55)">Slim</button>
            <button class="btn-ui" onclick="setSnakeSize(0.68)">Balanced</button>
            <button class="btn-ui" onclick="setSnakeSize(0.8)">Chunky</button>
        </div>

        <!-- Appearance section -->
        <div class="settings-section-title">Snake Color</div>
        <div class="settings-row">
            <button class="btn-ui" onclick="setSnakeColor('#3cf5ff', '#4571e3')">Soul Blue</button>
            <button class="btn-ui" onclick="setSnakeColor('#2ecc71', '#27ae60')">Emerald</button>
            <button class="btn-ui" onclick="setSnakeColor('#e67e22', '#d35400')">Inferno</button>
            <button class="btn-ui" onclick="setSnakeColor('#ff6bd5', '#ffce44')">Neon Forge</button>
        </div>

        <!-- Audio -->
        <div class="settings-section-title">Audio</div>
        <div class="settings-row">
            <button class="btn-ui" id="audio-toggle" onclick="toggleAudio()">Sound: ON</button>
        </div>

        <button class="btn-ui" style="margin-top:20px;" onclick="hideScreens()">Return</button>
    </div>
</div>

<!-- Leaderboard Screen -->
<div id="board-layer" class="screen hidden">
    <h2 style="color:var(--accent); letter-spacing:10px; margin-bottom: 25px; text-shadow:0 0 18px rgba(255,206,68,0.9);">HALL OF FAME</h2>
    <div class="container-box" id="leaderboard-list"></div>
    <button class="btn-ui" style="margin-top:25px;" onclick="hideScreens()">Return</button>
</div>

<!-- Credits Screen -->
<div id="credits-layer" class="screen hidden" onclick="hideScreens()">
    <h2 style="color:var(--accent); letter-spacing:15px; margin-bottom: 25px; text-shadow:0 0 18px rgba(255,206,68,0.9);">CREDITS</h2>
